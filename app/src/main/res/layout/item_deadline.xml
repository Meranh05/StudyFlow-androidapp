<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="false"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider"
    app:cardBackgroundColor="@color/surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="104dp"
        android:padding="16dp">

        <!-- Priority bar -->
        <View
            android:id="@+id/view_priority"
            android:layout_width="5dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_priority_bar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Subject chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_subject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mobile App"
            android:textSize="11sp"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:checkable="false"
            android:clickable="false"
            android:minHeight="30dp"
            app:chipMinHeight="30dp"
            app:chipCornerRadius="15dp"
            app:chipBackgroundColor="@color/priority_medium_bg"
            app:ensureMinTouchTargetSize="false"
            app:layout_constraintStart_toEndOf="@id/view_priority"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="12dp" />

        <!-- Status badge -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TODO"
            android:textSize="11sp"
            android:fontFamily="@font/inter_semi_bold"
            android:textColor="@color/primary"
            android:background="@drawable/bg_status_badge"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/inter_semi_bold"
            android:text="Hoàn thành bài tập giao diện StudyFlow"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:lineSpacingExtra="2dp"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/view_priority"
            app:layout_constraintTop_toBottomOf="@id/chip_subject"
            app:layout_constraintEnd_toStartOf="@id/tv_status"
            app:layout_constraintHorizontal_bias="0" />

        <!-- Due label icon + date -->
        <ImageView
            android:id="@+id/iv_due"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="10dp"
            android:src="@drawable/ic_calendar"
            android:contentDescription="@null"
            app:tint="@color/text_secondary"
            app:layout_constraintStart_toEndOf="@id/view_priority"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <TextView
            android:id="@+id/tv_due_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Hạn nộp: 29/03/2026 • 23:59"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/iv_due"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/iv_due"
            app:layout_constraintBottom_toBottomOf="@id/iv_due" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>