<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:paddingBottom="40dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/divider"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tv_sheet_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm môn học"
        android:textSize="18sp"
        android:fontFamily="@font/inter_bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Tên môn học *"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
        android:layout_marginBottom="14dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapWords"
            android:imeOptions="actionNext"/>

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_lecturer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Giảng viên"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
        android:layout_marginBottom="14dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_lecturer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapWords"
            android:imeOptions="actionNext"/>

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_credits"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Số tín chỉ"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_credits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:imeOptions="actionDone"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Color picker -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Màu tag"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="10dp"/>

    <LinearLayout
        android:id="@+id/layout_colors"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <!-- 6 color circles, tạo bằng code trong Fragment -->

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hủy"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lưu"
            android:minHeight="48dp"
            android:paddingVertical="12dp"
            android:layout_marginStart="8dp"
            style="@style/Widget.Material3.Button"
            app:cornerRadius="12dp"/>

    </LinearLayout>

</LinearLayout>